# Copy to .env and fill in. Never commit .env.
#
#   cp .env.example .env

# Shared bearer token the enclave sends to the vault at boot (external-config vault-token).
VAULT_TOKEN=

# Secret value the vault releases to attested enclaves of this repo.
EXAMPLE_KEY=

# Optional dev-launch / local overrides:
# CVMIMAGE_DIR=/path/to/cvmimage
# DOMAIN=my-test.box3.tinfoil.sh
# TINFOILD=http://localhost:8080
